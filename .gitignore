### Eclipse ###
.metadata
tmp/
*.tmp
*.bak
*.swp
*~.nib
local.properties
.settings/
.loadpath
.recommenders

# External tool builders
#.externalToolBuilders/

# Locally stored "Eclipse launch configurations"
*.launch

# Java annotation processor (APT)
.factorypath

# Code Recommenders
.recommenders/

### Eclipse Patch ###
# Eclipse Core — freemind/.project and freemind/.classpath are tracked for Eclipse users
# Root .project is auto-generated by Buildship and should not be committed
/.project
#.classpath
# Plugin-level Eclipse files (auto-generated by Buildship, not tracked)
freemind/plugins/**/.project
freemind/plugins/**/.classpath

### Java ###
# Compiled class files
*.class

# Log files
*.log

# Package Files — JAR/ZIP are NOT ignored (project uses local JARs as dependencies)
#*.jar
#*.zip
*.tar.gz
*.rar

# Virtual machine crash logs
hs_err_pid*
replay_pid*

### Gradle ###
.gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

### IntelliJ IDEA ###
.idea/
*.iml
*.ipr
*.iws
out/

### VS Code ###
.vscode/
*.code-workspace

### macOS ###
.DS_Store
._*

### Windows ###
Thumbs.db
Desktop.ini

### FreeMind CE specific ###

# Auto-generated at runtime
freemind/version.properties
freemind/auto.properties
freemind/.jqwik-database

# JiBX binding JAR (obsolete — replaced by JAXB)
freemind/lib/bindings.jar

# Build output directories (legacy Ant)
bin/dist/
bin/classes/
bin/testclasses/
bin/reports/

# Distribution artifacts
*.dmg
*.pkg
*.exe
*.msi
*.deb
*.rpm

# Test coverage
jacoco/
coverage/

# Legacy Ant build output inside freemind/
freemind/bin/

# Claude Code — ignore local settings but keep project settings and hooks
.claude/*
!.claude/settings.json
!.claude/hooks/
.claude/settings.local.json
.claude/worktrees/
.claude/plans/

# Serena LSP agent (keep .serena/project.yml versioned)
.serena/project.local.yml
.serena/memories/
.serena/cache/
.serena/logs/
.serena/.gitignore

# BMAD workflow framework and output artifacts (local tooling)
_bmad/
_bmad-output/

# Content marketing materials (local only, not committed)
docs/content-marketing/
